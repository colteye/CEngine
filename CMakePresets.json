{
  "version": 3,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CENGINE_ENABLE_OPENGL": "ON",
        "CENGINE_ENABLE_VULKAN": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CENGINE_ENABLE_OPENGL": "ON",
        "CENGINE_ENABLE_VULKAN": "OFF"
      }
    },
    {
      "name": "mac-debug",
      "displayName": "macOS Debug",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/mac-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "mac-release",
      "displayName": "macOS Release",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/mac-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "debug-headless",
      "displayName": "Debug Headless Compile Check",
      "binaryDir": "${sourceDir}/build/debug-headless",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CENGINE_ENABLE_OPENGL": "ON",
        "CENGINE_ENABLE_VULKAN": "OFF",
        "CENGINE_FETCH_GLFW_X11": "OFF",
        "CENGINE_FETCH_GLFW_WAYLAND": "OFF"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-debug",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CENGINE_ENABLE_OPENGL": "ON",
        "CENGINE_ENABLE_VULKAN": "OFF"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows Release",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-release",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CENGINE_ENABLE_OPENGL": "ON",
        "CENGINE_ENABLE_VULKAN": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "Debug"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release"
    },
    {
      "name": "mac-debug",
      "configurePreset": "mac-debug",
      "configuration": "Debug"
    },
    {
      "name": "mac-release",
      "configurePreset": "mac-release",
      "configuration": "Release"
    },
    {
      "name": "debug-headless",
      "configurePreset": "debug-headless",
      "configuration": "Debug"
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release"
    }
  ]
}
